# Optional — map embed (Google Maps JavaScript API)
VITE_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Production: public URL of your ASP.NET API (no trailing slash). Example: https://api-neighborhood-intel.railway.app
# Leave unset for local dev (Vite proxies /api to localhost:5000).
# VITE_API_BASE_URL=https://your-api-host.example.com
